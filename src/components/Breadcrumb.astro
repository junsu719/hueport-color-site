---
export interface BreadcrumbItem {
  name: string;
  href?: string;
}

export interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
const site = Astro.site ?? new URL('https://hueport-color-site.pages.dev');

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    ...(item.href ? { item: new URL(item.href, site).toString() } : {}),
  })),
};
---
<nav aria-label="Breadcrumb" class="mb-6 text-sm text-neutral-500">
  <ol class="flex flex-wrap items-center gap-1">
    {items.map((item, index) => (
      <li class="flex items-center gap-1">
        {index > 0 && <span aria-hidden="true">/</span>}
        {item.href ? (
          <a href={item.href} class="hover:text-neutral-900 hover:underline">{item.name}</a>
        ) : (
          <span class="text-neutral-700" aria-current="page">{item.name}</span>
        )}
      </li>
    ))}
  </ol>
</nav>
<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
