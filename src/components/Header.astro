---
const navLinks = [
  { href: '/tools/', label: 'Tools' },
  { href: '/colors/', label: 'Colors' },
  { href: '/app/', label: 'Get the App' },
];
---
<header class="border-b border-neutral-200 bg-white">
  <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-x-6 gap-y-3 px-4 py-4">
    <a href="/" class="text-lg font-semibold text-neutral-900">HuePort Color</a>
    <nav aria-label="Primary" class="flex flex-wrap items-center gap-x-6 gap-y-2 text-sm text-neutral-600">
      {navLinks.map((link) => (
        <a href={link.href} class="hover:text-neutral-900">{link.label}</a>
      ))}
    </nav>
  </div>
</header>
